<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
    <string>$(CAPACITOR_DEBUG)</string>

    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>

    <key>CFBundleDisplayName</key>
    <string>FanZone</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>

    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- Deep linking URL schemes -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.fanzone.app</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>fanzone</string>
            </array>
        </dict>
    </array>

    <!-- Associated Domains for Universal Links (App Links) -->
    <!-- Enable in Xcode: Signing & Capabilities → Associated Domains → applinks:app.fanzone.com -->

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- Privacy usage descriptions -->
    <key>NSCameraUsageDescription</key>
    <string>FanZone needs camera access to let you upload photos for your fan profile and posts.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>FanZone needs photo library access to let you choose images for your fan profile.</string>

    <key>NSLocationWhenInUseUsageDescription</key>
    <string>FanZone uses your location to show nearby stadiums and fan meetups.</string>

    <key>NSUserNotificationsUsageDescription</key>
    <string>FanZone sends notifications for match alerts, group messages, and score predictions.</string>

    <!-- Push notifications background mode -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>fetch</string>
    </array>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
    </array>

    <!-- Lock to portrait for phone; allow landscape on iPad -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- Status bar dark content (light backgrounds) -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>

    <!-- Keyboard adjustment -->
    <key>UIScrollViewContentInsetAdjustmentBehavior</key>
    <string>automatic</string>

    <!-- Safe area support -->
    <key>UIViewEdgeAntialiasing</key>
    <false/>
</dict>
</plist>
